package com.iamconanpeter.chromadrop

import androidx.compose.runtime.getValue
import androidx.compose.runtime.mutableStateOf
import androidx.compose.runtime.setValue
import kotlin.random.Random

class GameEngine(
    val rows: Int = 16,
    val cols: Int = 8,
    private val random: Random = Random.Default
) {
    enum class CellColor {
        RED,
        GREEN,
        BLUE,
        YELLOW
    }

    data class FallingPair(
        val row: Int,
        val col: Int,
        val orientation: Int,
        val primary: CellColor,
        val secondary: CellColor
    )

    var board by mutableStateOf(emptyBoard())
        private set

    var currentPair by mutableStateOf<FallingPair?>(null)
        private set

    var score by mutableStateOf(0)
        private set

    var isGameOver by mutableStateOf(false)
        private set

    init {
        spawnPair()
    }

    fun restart() {
        board = emptyBoard()
        score = 0
        isGameOver = false
        currentPair = null
        spawnPair()
    }

    fun tick() {
        if (isGameOver) return

        val pair = currentPair
        if (pair == null) {
            spawnPair()
            return
        }

        val moved = pair.copy(row = pair.row + 1)
        if (canPlace(moved)) {
            currentPair = moved
        } else {
            lockCurrentPair()
        }
    }

    fun moveLeft() {
        moveHorizontal(-1)
    }

    fun moveRight() {
        moveHorizontal(1)
    }

    fun rotate() {
        if (isGameOver) return
        val pair = currentPair ?: return

        val rotated = pair.copy(orientation = (pair.orientation + 1) % 4)
        val kicks = listOf(0, -1, 1, -2, 2)
        for (kick in kicks) {
            val candidate = rotated.copy(col = rotated.col + kick)
            if (canPlace(candidate)) {
                currentPair = candidate
                return
            }
        }
    }

    fun softDrop() {
        if (isGameOver) return
        val before = currentPair?.row ?: return
        tick()
        val after = currentPair?.row
        if (after != null && after > before) {
            score += 1
        }
    }

    fun hardDrop() {
        if (isGameOver) return
        var pair = currentPair ?: return
        var dropped = 0

        while (true) {
            val moved = pair.copy(row = pair.row + 1)
            if (!canPlace(moved)) break
            pair = moved
            dropped++
        }

        currentPair = pair
        score += dropped * 2
        lockCurrentPair()
    }

    fun activeCells(): List<Triple<Int, Int, CellColor>> {
        val pair = currentPair ?: return emptyList()
        return pairCells(pair)
    }

    private fun moveHorizontal(delta: Int) {
        if (isGameOver) return
        val pair = currentPair ?: return
        val moved = pair.copy(col = pair.col + delta)
        if (canPlace(moved)) {
            currentPair = moved
        }
    }

    private fun spawnPair() {
        if (isGameOver) return

        val pair = FallingPair(
            row = 0,
            col = cols / 2,
            orientation = 2,
            primary = randomColor(),
            secondary = randomColor()
        )

        if (canPlace(pair)) {
            currentPair = pair
        } else {
            isGameOver = true
            currentPair = null
        }
    }

    private fun lockCurrentPair() {
        val pair = currentPair ?: return
        val mutable = board.map { it.toMutableList() }

        for ((row, col, color) in pairCells(pair)) {
            if (row < 0) {
                isGameOver = true
                currentPair = null
                return
            }
            mutable[row][col] = color
        }

        board = mutable.map { it.toList() }
        currentPair = null

        resolveMatchesAndGravity()

        if (!isGameOver) {
            spawnPair()
        }
    }

    private fun resolveMatchesAndGravity() {
        while (true) {
            val matches = findMatches(board)
            if (matches.isEmpty()) return

            val mutable = board.map { it.toMutableList() }
            for ((row, col) in matches) {
                mutable[row][col] = null
            }
            board = mutable.map { it.toList() }
            score += matches.size * 10

            applyGravity()
        }
    }

    private fun applyGravity() {
        val mutable = board.map { it.toMutableList() }

        for (col in 0 until cols) {
            var writeRow = rows - 1
            for (row in rows - 1 downTo 0) {
                val cell = mutable[row][col]
                if (cell != null) {
                    mutable[writeRow][col] = cell
                    if (writeRow != row) {
                        mutable[row][col] = null
                    }
                    writeRow--
                }
            }
            while (writeRow >= 0) {
                mutable[writeRow][col] = null
                writeRow--
            }
        }

        board = mutable.map { it.toList() }
    }

    private fun findMatches(state: List<List<CellColor?>>): Set<Pair<Int, Int>> {
        val visited = Array(rows) { BooleanArray(cols) }
        val matches = mutableSetOf<Pair<Int, Int>>()

        for (startRow in 0 until rows) {
            for (startCol in 0 until cols) {
                val color = state[startRow][startCol] ?: continue
                if (visited[startRow][startCol]) continue

                val queue = ArrayDeque<Pair<Int, Int>>()
                val group = mutableListOf<Pair<Int, Int>>()

                queue.add(startRow to startCol)
                visited[startRow][startCol] = true

                while (queue.isNotEmpty()) {
                    val (row, col) = queue.removeFirst()
                    group.add(row to col)

                    val neighbors = listOf(
                        row - 1 to col,
                        row + 1 to col,
                        row to col - 1,
                        row to col + 1
                    )

                    for ((nextRow, nextCol) in neighbors) {
                        if (nextRow !in 0 until rows || nextCol !in 0 until cols) continue
                        if (visited[nextRow][nextCol]) continue
                        if (state[nextRow][nextCol] != color) continue

                        visited[nextRow][nextCol] = true
                        queue.add(nextRow to nextCol)
                    }
                }

                if (group.size >= 3) {
                    matches.addAll(group)
                }
            }
        }

        return matches
    }

    private fun canPlace(pair: FallingPair): Boolean {
        for ((row, col, _) in pairCells(pair)) {
            if (col !in 0 until cols) return false
            if (row >= rows) return false
            if (row >= 0 && board[row][col] != null) return false
        }
        return true
    }

    private fun pairCells(pair: FallingPair): List<Triple<Int, Int, CellColor>> {
        val primaryCell = Triple(pair.row, pair.col, pair.primary)

        val (rowOffset, colOffset) = when (pair.orientation % 4) {
            0 -> -1 to 0
            1 -> 0 to 1
            2 -> 1 to 0
            else -> 0 to -1
        }

        val secondaryCell = Triple(
            pair.row + rowOffset,
            pair.col + colOffset,
            pair.secondary
        )

        return listOf(primaryCell, secondaryCell)
    }

    private fun randomColor(): CellColor {
        return CellColor.entries[random.nextInt(CellColor.entries.size)]
    }

    private fun emptyBoard(): List<List<CellColor?>> {
        return List(rows) { List(cols) { null } }
    }
}
